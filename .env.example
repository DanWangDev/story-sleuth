# ─── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5060
CORS_ORIGIN=http://localhost:5180

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgres://story_sleuth:story_sleuth@localhost:5432/story_sleuth

# ─── 11plus-hub OIDC ────────────────────────────────────────────────
# Public issuer URL — must match JWT `iss` claim.
OIDC_ISSUER=http://localhost:3009
# Docker-internal issuer for discovery/JWKS fetch when backend talks
# to hub over the compose network. Omit if the same as OIDC_ISSUER.
# OIDC_INTERNAL_ISSUER=http://hub-app:3009

# OIDC client credentials (register story-sleuth in hub's `applications`
# table first). client_secret must NEVER be committed.
OIDC_CLIENT_ID=story-sleuth-client
OIDC_CLIENT_SECRET=replace-me

# Where the hub redirects back to after login. Matches a redirect_uri
# registered for this client in the hub.
OIDC_REDIRECT_URI=http://localhost:5180/api/auth/callback

# ─── Session / cookies ─────────────────────────────────────────────
# 32+ byte random string. Rotating invalidates all sessions.
#   openssl rand -base64 32
SESSION_SECRET=replace-me-with-at-least-32-bytes-of-random

# ─── App slug ───────────────────────────────────────────────────────
# Hub includes this in the `apps` claim when the user is subscribed.
# Auth middleware rejects sessions whose `apps` claim doesn't include it.
APP_SLUG=reading

# ─── Frontend build-time ────────────────────────────────────────────
VITE_API_URL=/api
VITE_HUB_URL=http://localhost:3009
