# ─── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5060
CORS_ORIGIN=http://localhost:5180

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgres://story_sleuth:story_sleuth@localhost:5432/story_sleuth

# ─── 11plus-hub OIDC ────────────────────────────────────────────────
# Public issuer URL — must match JWT `iss` claim.
OIDC_ISSUER=http://localhost:3009
# Docker-internal issuer for discovery/JWKS fetch when backend talks
# to hub over the shared labf-net network. The compose files default
# this to http://hub-backend:3009 — only set here if you want to
# override for local dev (e.g. pointing at a non-containerised hub).
# OIDC_INTERNAL_ISSUER=http://hub-backend:3009

# OIDC client credentials (register story-sleuth in hub's `applications`
# table first). client_secret must NEVER be committed.
OIDC_CLIENT_ID=story-sleuth-client
OIDC_CLIENT_SECRET=replace-me

# Where the hub redirects back to after login. Matches a redirect_uri
# registered for this client in the hub.
OIDC_REDIRECT_URI=http://localhost:5180/api/auth/callback

# ─── Session / cookies ─────────────────────────────────────────────
# 32+ byte random string. Rotating invalidates all sessions.
#   openssl rand -base64 32
SESSION_SECRET=replace-me-with-at-least-32-bytes-of-random

# ─── App slug ───────────────────────────────────────────────────────
# Hub includes this in the `apps` claim when the user is subscribed.
# Auth middleware rejects sessions whose `apps` claim doesn't include it.
APP_SLUG=reading

# ─── Admin settings encryption ─────────────────────────────────────
# Base64-encoded 32 bytes. Encrypts admin_settings values (LLM API keys).
# Generate once per environment and NEVER commit:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
ADMIN_ENCRYPTION_KEY=replace-me-with-base64-encoded-32-bytes

# ─── Content pipeline ───────────────────────────────────────────────
# Directory holding the passage manifest .md files. Dev default points
# at the repo's content/passages/. In the backend Docker image it's
# /app/content/passages (set by the Dockerfile).
CONTENT_PATH=../../content/passages

# ─── Frontend build-time ────────────────────────────────────────────
VITE_API_URL=/api
VITE_HUB_URL=http://localhost:3009

# ─── Production (docker-compose.prod.yml only) ─────────────────────
# Used by deploy.sh + docker-compose.prod.yml. Leave these empty in dev.
#
# Pin image tags to a commit SHA (e.g. IMAGE_TAG=8eb46e3) for a safe
# rollback; use "latest" during normal deploys.
# IMAGE_TAG=latest
#
# Postgres: username and db default to "story_sleuth" if unset. Password
# has NO default — compose refuses to start without it.
# POSTGRES_USER=story_sleuth
# POSTGRES_DB=story_sleuth
# POSTGRES_PASSWORD=
#
# Cloudflare Zero Trust tunnel token. Get this from the Zero Trust
# dashboard → Access → Tunnels → <your tunnel> → Install connector.
# Configure the public hostname → http://frontend:80 mapping in the
# same dashboard.
# CLOUDFLARE_TUNNEL_TOKEN=
